---
import { SITE } from "@/lib/site";

type Props = {
  title?: string;
  description?: string;
  urlPath?: string;
  image?: string;
  noindex?: boolean;
  icons?: boolean;
  isPost?: boolean;
  publishedTime?: Date;
  modifiedTime?: Date;
  tags?: string[];
  contentText?: string;
};

const {
  title,
  description,
  urlPath,
  image,
  noindex = false,
  icons = false,
  isPost = false,
  publishedTime,
  modifiedTime,
  tags = [],
  contentText,
} = Astro.props;

const resolvedTitle = title ?? SITE.title;
const resolvedDescription = description ?? SITE.description;
const canonicalPath = urlPath ?? Astro.url.pathname;
const canonicalUrl = new URL(canonicalPath, SITE.url).toString().toLowerCase();

const socialImage = new URL(image ?? "/images/LM-portrait.jpg", SITE.url).toString();

const schemaGraph: Record<string, unknown>[] = [
  {
    "@context": "https://schema.org/",
    "@type": "WebPage",
    name: SITE.title,
    speakable: {
      "@type": "SpeakableSpecification",
      cssSelector: ["#SpeakableHeadline", "#SpeakableSummary"],
    },
    url: canonicalUrl,
  },
  {
    "@context": "http://schema.org",
    "@type": "Person",
    familyName: "Murdock",
    givenName: "Lukas",
    url: SITE.url,
    email: SITE.email,
    address: {
      "@type": "PostalAddress",
      addressLocality: "Columbus",
      addressRegion: "Ohio",
      postalCode: "43035",
      addressCountry: "USA",
    },
    birthDate: "2000-12-09",
    gender: "Male",
    jobTitle: "Designer, Developer, Marketer",
    image: `${SITE.url}/images/LM-portrait.jpg`,
    description:
      "Lukas Murdock is a Designer, Developer, and Marketer doing work that matters for people who care.",
    sameAs: [
      "https://www.linkedin.com/in/lukas-murdock/",
      "https://twitter.com/MurdockLukas",
      "https://github.com/LukasMurdock",
      "https://www.facebook.com/lukas.rex.murdock",
      "https://www.instagram.com/lukasauras.rex/",
      "https://www.youtube.com/channel/UCG8ZhvCtKlnPXkoJG2u52lw",
    ],
    worksFor: {
      "@type": "Organization",
      name: "SKYCATCHFIRE",
    },
  },
  {
    "@context": "http://www.schema.org",
    "@type": "WebSite",
    name: SITE.title,
    url: SITE.url,
  },
];

if (isPost) {
  schemaGraph.push({
    "@type": "BlogPosting",
    mainEntityOfPage: {
      "@type": "WebPage",
      "@id": `${SITE.url}/writing/`,
    },
    headline: resolvedTitle,
    url: canonicalUrl,
    datePublished: publishedTime?.toISOString(),
    dateModified: (modifiedTime ?? publishedTime)?.toISOString(),
    image: image ?? "",
    author: {
      "@type": "Person",
      name: "Lukas Murdock",
      description:
        "Lukas Murdock helps people do work that matters for people who care. Exploring design, development, and marketing.",
      sameAs: [
        "https://www.linkedin.com/in/lukas-murdock/",
        "https://twitter.com/MurdockLukas",
        "https://github.com/LukasMurdock",
        "https://www.facebook.com/lukas.rex.murdock",
        "https://www.instagram.com/lukasauras.rex/",
        "https://www.youtube.com/channel/UCG8ZhvCtKlnPXkoJG2u52lw",
      ],
      image: {
        "@type": "ImageObject",
        url: `${SITE.url}/images/LM-portrait.jpg`,
      },
      givenName: "Lukas",
      familyName: "Murdock",
      publishingPrinciples: SITE.url,
      email: SITE.email,
    },
    publisher: {
      "@type": "Organization",
      name: "Lukas Murdock",
      url: SITE.url,
      logo: {
        "@type": "ImageObject",
        width: 60,
        height: 60,
        url: `${SITE.url}/android-chrome-512x512.png`,
      },
    },
    description: resolvedDescription,
    articleBody: contentText,
    keywords: tags.join(","),
    inLanguage: "en-US",
  });
}

const schema = {
  "@context": "http://www.schema.org",
  "@graph": schemaGraph,
};
---

<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  {noindex && <meta name="robots" content="noindex" />}
  <title>{resolvedTitle}</title>
  <meta name="description" content={resolvedDescription} />
  <link rel="canonical" href={canonicalUrl} />
  <meta property="og:type" content="website" />
  <meta property="og:title" content={resolvedTitle} />
  <meta property="og:locale" content="en_US" />
  <meta property="og:description" content={resolvedDescription} />
  <meta property="og:url" content={canonicalUrl} />
  <meta property="og:site_name" content={SITE.title} />
  <meta property="og:image" content={socialImage} />
  <meta name="twitter:card" content="summary" />
  <meta property="twitter:image" content={socialImage} />
  <meta property="twitter:title" content={resolvedTitle} />
  <meta name="twitter:site" content="@Lukasauras_Rex" />
  <meta name="twitter:creator" content="@Lukasauras_Rex" />
  <meta name="author" content="MurdockLukas" />
  <link rel="stylesheet" type="text/css" href="/css/main.css" />
  <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
  <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
  <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
  <link rel="manifest" href="/site.webmanifest" />
  <link rel="mask-icon" href="/safari-pinned-tab.svg" color="#f94643" />
  <meta name="msapplication-TileColor" content="#ffffff" />
  <meta name="msapplication-TileImage" content="/ms-icon-144x144.png" />
  <meta name="theme-color" content="#ffffff" />
  <meta
    name="ahrefs-site-verification"
    content="cdfe02e1e8a05e4ff05b25088bb723d7cd2cab01fba8a08223274bf41a12e4a3"
  />
  <meta name="google-site-verification" content="fPk8VHNqhVzOb2qHw5K0bg3w8WrInKiLQeqZBOteVFA" />

  {icons && (
    <>
      <link rel="stylesheet" type="text/css" href="/css/icons.css" />
      <script src="/js/icons.js" async is:inline></script>
    </>
  )}

  {publishedTime && <meta property="article:published_time" content={publishedTime.toISOString()} />}
  {modifiedTime && <meta property="article:modified_time" content={modifiedTime.toISOString()} />}

  <script type="application/ld+json" set:html={JSON.stringify(schema)} is:inline></script>
</head>
