---
import BaseLayout from "@/layouts/BaseLayout.astro";
---

<BaseLayout
  title="Resources"
  description="Resources to Explore — We can use the internet to explore the places that we know we should be exploring."
  urlPath="/resources/"
>
  <style is:inline>
    h1 {
      text-align: center;
      margin-bottom: 0;
    }
  </style>

  <p style="text-align:center; margin-top: 2px;">Abundant means; scarce desires.</p>

  <div class="cardgrid-container">
    <div class="card-noshadow two-column">
      <div class="resource-text">
        <h2 class="resource-title">Knowledge</h2>
        <a href="/knowledge/">Explore design, development, and marketing&nbsp;&rarr;</a>
        <svg preserveAspectRatio="xMinYMax meet" width="100%" viewBox="0 0 600 360" xmlns="http://www.w3.org/2000/svg">
          <defs>
            <linearGradient id="knowledgeOrbResources1" x1="0" y1="0" x2="1" y2="1">
              <stop offset="0%" stop-color="#84fab0"></stop>
              <stop offset="100%" stop-color="#8fd3f4"></stop>
            </linearGradient>
            <linearGradient id="knowledgeOrbResources2" x1="1" y1="0" x2="0" y2="1">
              <stop offset="0%" stop-color="#8fd3f4"></stop>
              <stop offset="100%" stop-color="#84fab0"></stop>
            </linearGradient>
            <linearGradient id="knowledgeOrbResources3" x1="0" y1="1" x2="1" y2="0">
              <stop offset="0%" stop-color="#9dfbbf"></stop>
              <stop offset="100%" stop-color="#8fd3f4"></stop>
            </linearGradient>
          </defs>
          <circle cx="170" cy="246" r="108" fill="url(#knowledgeOrbResources1)" fill-opacity="0.92"></circle>
          <circle cx="300" cy="246" r="108" fill="url(#knowledgeOrbResources2)" fill-opacity="0.88"></circle>
          <circle cx="430" cy="246" r="108" fill="url(#knowledgeOrbResources3)" fill-opacity="0.92"></circle>
        </svg>
      </div>
    </div>

    <div class="card-noshadow two-column">
      <div class="resource-text">
        <h2 class="resource-title">Around the Web</h2>
        <a href="/aroundtheweb/">Links from all over&nbsp;&rarr;</a>
        <svg
          preserveAspectRatio="xMinYMax meet"
          style="vertical-align:top; flex-grow: 1;"
          viewBox="0 0 1144 561"
          xmlns="http://www.w3.org/2000/svg"
          fill-rule="evenodd"
          clip-rule="evenodd"
          stroke-linejoin="round"
          stroke-miterlimit="2"
          ><path d="M396.855 561.959a173.366 173.366 0 01-.833-17.004c0-94.86 77.015-171.875 171.875-171.875s171.875 77.015 171.875 171.875c0 5.739-.282 11.413-.833 17.004H396.855z" fill="url(#aroundthewebGradient1)"></path><circle cx="329.555" cy="213.288" r="115.625" fill="url(#aroundthewebGradient2)"></circle><circle cx="93.75" cy="466.83" r="93.75" fill="url(#aroundthewebGradient3)"></circle><circle cx="924.639" cy="432.678" r="78.125" fill="url(#aroundthewebGradient4)"></circle><circle cx="1002.76" cy="140.625" r="140.625" fill="url(#aroundthewebGradient5)"></circle><defs><linearGradient id="aroundthewebGradient1" x1="0" y1="0" x2="1" y2="0" gradientUnits="userSpaceOnUse" gradientTransform="rotate(-26.115 1488.188 -397.719) scale(548.37)"><stop offset="0" stop-color="#9dfbbf"></stop><stop offset="1" stop-color="#a2dbf6"></stop></linearGradient><linearGradient id="aroundthewebGradient2" x1="0" y1="0" x2="1" y2="0" gradientUnits="userSpaceOnUse" gradientTransform="scale(408.552) rotate(65.538 .245 .502)"><stop offset="0" stop-color="#84fab0"></stop><stop offset="1" stop-color="#f2f2f2"></stop></linearGradient><linearGradient id="aroundthewebGradient3" x1="0" y1="0" x2="1" y2="0" gradientUnits="userSpaceOnUse" gradientTransform="rotate(-23.147 1247.17 255.4) scale(252.617)"><stop offset="0" stop-color="#84fab0"></stop><stop offset="1" stop-color="#f2f2f2"></stop></linearGradient><linearGradient id="aroundthewebGradient4" x1="0" y1="0" x2="1" y2="0" gradientUnits="userSpaceOnUse" gradientTransform="scale(-252.83) rotate(-38.17 -4.056 5.164)"><stop offset="0" stop-color="#8fd3f4"></stop><stop offset="1" stop-color="#e5feee"></stop></linearGradient><linearGradient id="aroundthewebGradient5" x1="0" y1="0" x2="1" y2="0" gradientUnits="userSpaceOnUse" gradientTransform="scale(356.574) rotate(-33.849 2.258 -3.625)"><stop offset="0" stop-color="#e5feee"></stop><stop offset="1" stop-color="#8fd3f4"></stop></linearGradient></defs></svg
        >
      </div>
    </div>

    <div class="card-noshadow two-column">
      <div class="resource-text">
        <h2 class="resource-title">Booklist</h2>
        <a href="/booklist/">Books I really don&rsquo;t want to forget&nbsp;&rarr;</a>
        <svg preserveAspectRatio="xMinYMax meet" width="100%" viewBox="0 0 600 360" xmlns="http://www.w3.org/2000/svg">
          <defs>
            <linearGradient id="bookResourcesCover1" x1="0" y1="0" x2="1" y2="1">
              <stop offset="0%" stop-color="#9dfbbf"></stop>
              <stop offset="100%" stop-color="#8fd3f4"></stop>
            </linearGradient>
            <linearGradient id="bookResourcesCover2" x1="1" y1="0" x2="0" y2="1">
              <stop offset="0%" stop-color="#8fd3f4"></stop>
              <stop offset="100%" stop-color="#9dfbbf"></stop>
            </linearGradient>
          </defs>
          <rect x="58" y="146" width="136" height="258" rx="12" fill="url(#bookResourcesCover1)"></rect>
          <rect x="232" y="146" width="136" height="258" rx="12" fill="url(#bookResourcesCover2)"></rect>
          <rect x="406" y="146" width="136" height="258" rx="12" fill="url(#bookResourcesCover1)"></rect>
        </svg>
      </div>
    </div>

    <div class="card-noshadow two-column">
      <div class="resource-text">
        <h2 class="resource-title">Principles</h2>
        <a href="/principles/">See things dispassionately for what they are&nbsp;&rarr;</a>
        <svg
          preserveAspectRatio="xMinYMax meet"
          style="vertical-align:top;"
          viewBox="0 0 1063 562"
          xmlns="http://www.w3.org/2000/svg"
          fill-rule="evenodd"
          clip-rule="evenodd"
          stroke-linejoin="round"
          stroke-miterlimit="2"
          ><path d="M.875 561.959A537.852 537.852 0 010 531.25C0 238.045 238.045 0 531.25 0c293.205 0 531.25 238.045 531.25 531.25 0 10.321-.295 20.573-.875 30.709H.875z" fill="#8fd3f4" fill-opacity=".4"></path><path d="M126.147 561.959A410.383 410.383 0 01125 531.25C125 307.035 307.035 125 531.25 125S937.5 307.035 937.5 531.25c0 10.336-.387 20.583-1.147 30.709H126.147z" fill="#8fd3f4" fill-opacity=".5"></path><path d="M251.661 561.959A283.748 283.748 0 01250 531.25C250 376.024 376.024 250 531.25 250S812.5 376.024 812.5 531.25c0 10.369-.562 20.608-1.661 30.709H251.661z" fill="#8fd3f4" fill-opacity=".6"></path><path d="M256.435 152.429l-60.371-16.176-16.176 60.37 60.37 16.177 16.177-60.371z" fill="url(#principlesGradient1)"></path><path d="M1026.39 281.25v-62.5h-62.5v62.5h62.5z" fill="url(#principlesGradient2)"></path><path d="M684.958 270.641l-31.25-54.127-54.127 31.25 31.25 54.127 54.127-31.25z" fill="url(#principlesGradient3)"></path><path d="M191.947 444.293l-54.126-31.25-31.25 54.127 54.126 31.25 31.25-54.127z" fill="url(#principlesGradient4)"></path><path d="M393.889 561.959L363.18 531.25l176.777-176.777L716.734 531.25l-30.709 30.709H393.889z" fill="url(#principlesGradient5)"></path><defs><linearGradient id="principlesGradient1" x1="0" y1="0" x2="1" y2="0" gradientUnits="userSpaceOnUse" gradientTransform="rotate(50.178 -26.613 247.727) scale(142.2205)"><stop offset="0" stop-color="#8fd3f4"></stop><stop offset="1" stop-color="#9dfbbf"></stop></linearGradient><linearGradient id="principlesGradient2" x1="0" y1="0" x2="1" y2="0" gradientUnits="userSpaceOnUse" gradientTransform="scale(-133.5591) rotate(-46.695 -5.67 8.255)"><stop offset="0" stop-color="#8fd3f4"></stop><stop offset="1" stop-color="#9dfbbf"></stop></linearGradient><linearGradient id="principlesGradient3" x1="0" y1="0" x2="1" y2="0" gradientUnits="userSpaceOnUse" gradientTransform="rotate(107.5 259.462 342.02) scale(137.1111)"><stop offset="0" stop-color="#8fd3f4"></stop><stop offset="1" stop-color="#9dfbbf"></stop></linearGradient><linearGradient id="principlesGradient4" x1="0" y1="0" x2="1" y2="0" gradientUnits="userSpaceOnUse" gradientTransform="scale(159.4469) rotate(9.342 -16.666 3.712)"><stop offset="0" stop-color="#8fd3f4"></stop><stop offset="1" stop-color="#9dfbbf"></stop></linearGradient><linearGradient id="principlesGradient5" x1="0" y1="0" x2="1" y2="0" gradientUnits="userSpaceOnUse" gradientTransform="matrix(707.107 0 0 414.971 186.404 458.216)"><stop offset="0" stop-color="#9dfbbf"></stop><stop offset="1" stop-color="#8fd3f4"></stop></linearGradient></defs></svg
        >
      </div>
    </div>
  </div>
</BaseLayout>
