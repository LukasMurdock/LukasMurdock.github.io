---
import { getCollection } from "astro:content";
import ShellLayout from "@/layouts/ShellLayout.astro";
import FlightRoutesGlobe from "@/components/FlightRoutesGlobe.astro";
import { getPostSlug, hasTag, isPublishablePost, sortPostsByDateDesc } from "@/lib/content";
import { SITE } from "@/lib/site";

const posts = sortPostsByDateDesc((await getCollection("posts")).filter((post) => isPublishablePost(post)));
const annualPosts = posts.filter((post) => hasTag(post, "annual"));
