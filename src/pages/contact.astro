---
import BaseLayout from "@/layouts/BaseLayout.astro";
---

<BaseLayout
  title="Contact"
  description="Start a project, schedule a meeting, or just say hello."
  urlPath="/contact/"
>
  <p style="text-align:center; margin-left: auto; margin-right: auto; width: 87.5%; margin-bottom: 55px;">
    Start a project, schedule a meeting, or just say hello.
  </p>

  <p style="text-align:center; margin-left: auto; margin-right: auto; width: 87.5%;">
    Find me on Twitter <a href="https://twitter.com/MurdockLukas">@MurdockLukas</a>
  </p>
  <p style="text-align:center; margin-left: auto; margin-right: auto; width: 87.5%;">
    Add me on <a href="https://www.linkedin.com/in/lukas-murdock/">LinkedIn</a>
  </p>

  <iframe
    class="mobile-hide"
    src="https://docs.google.com/forms/d/e/1FAIpQLSc16OxM_vqrm_ydrS-y8GQBSYzx36DV-TgAAIcz9EcH4JPV8g/viewform?embedded=true"
    style="margin: 20px auto 40px auto; border: 0;"
    width="571"
    height="753"
    >Loading...</iframe
  >

  <iframe
    class="mobile-show"
    src="https://docs.google.com/forms/d/e/1FAIpQLSc16OxM_vqrm_ydrS-y8GQBSYzx36DV-TgAAIcz9EcH4JPV8g/viewform?embedded=true"
    style="margin: 20px auto 40px auto; border: 0;"
