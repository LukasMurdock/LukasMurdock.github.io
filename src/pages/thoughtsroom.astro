<!doctype html>
<html lang="en">
  <head>
    <meta name="viewport" content="width=device-width, initial-scale=1, maximum-scale=1" />
    <meta charset="utf-8" />
    <meta name="robots" content="noindex" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
    <link rel="manifest" href="/site.webmanifest" />
    <link rel="mask-icon" href="/safari-pinned-tab.svg" color="#f94643" />
    <meta name="msapplication-TileColor" content="#b91d47" />
    <meta name="theme-color" content="#ffffff" />
    <title>thoughts room</title>
    <meta name="description" content="The thoughts room" />
    <meta name="author" content="Lukas Murdock" />

    <script src="https://cdnjs.cloudflare.com/ajax/libs/animejs/2.0.2/anime.min.js" is:inline></script>
    <script src="https://ajax.googleapis.com/ajax/libs/jquery/3.4.1/jquery.min.js" is:inline></script>

    <style>
      body {
        min-width: 100%;
        min-height: 100%;
        font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Oxygen-Sans, Ubuntu, Cantarell,
          "Helvetica Neue", sans-serif;
      }

      input {
        font-size: 16px;
        width: 100%;
        background-color: transparent;
        border: none;
        color: rgba(0, 0, 0, 0);
        outline: none;
        caret-color: transparent;
        text-decoration: none;
      }

      .center {
        top: 50%;
        left: 30%;
        width: 40%;
        margin: auto;
        position: absolute;
      }

      .ml13 {
        position: absolute;
        left: 0;
        width: 100%;
        top: 0;
        color: #aaa;
        transition: 0.3s;
        z-index: 1;
        text-align: left;
      }

      .ml13 .letter {
        display: inline-block;
        line-height: 1em;
      }

      select:focus {
        font-size: 24px;
      }

      @media screen and (max-width: 735px) {
        input {
          font-size: 24px;
        }

        .center {
          top: 50%;
          left: 10%;
          width: 80%;
        }
      }
    </style>
  </head>

  <body>
    <div class="center">
      <input id="textbox" type="text" placeholder="" autocomplete="off" autofocus />
      <label class="ml13">Begin typing</label>
    </div>

    <script is:inline>
      const textbox = document.getElementById("textbox");
      let hold = 0;

      window.onclick = function () {
        document.getElementById("textbox")?.focus();
      };

      textbox?.addEventListener("keyup", function (event) {
        document.getElementById("textbox")?.focus();

        if (event.key === "Enter") {
          hold = 1;
          validate();
          const input = document.getElementById("textbox");
          if (input instanceof HTMLInputElement) {
            input.value = "";
          }
        } else if (hold === 0) {
          const label = document.querySelector(".ml13");
          const input = document.getElementById("textbox");
          if (label && input instanceof HTMLInputElement) {
            label.innerHTML = input.value;
          }
        }
      });

      function reset() {
        hold = 0;
      }

      function validate() {
        const textWrapper = document.querySelector(".ml13");
        if (!textWrapper) {
          return;
        }

        textWrapper.innerHTML = textWrapper.textContent?.replace(/\S/g, "<span class='letter'>$&</span>") ?? "";

        window.anime
          .timeline({ loop: false })
          .add({
            targets: ".ml13 .letter",
            translateY: [0, -25],
            opacity: [1, 0],
            easing: "easeInExpo",
            duration: 600,
            rotate: function () {
              return window.anime.random(-30, 30);
            },
            delay: (_, index) => 14 * index,
          });

        setTimeout(function () {
          reset();
        }, 1200);
      }

      window.jQuery(document).ready(function () {
        document.ontouchmove = function (event) {
          event.preventDefault();
        };
      });

      textbox.onfocus = function () {
        window.scrollTo(0, 0);
        document.body.scrollTop = 0;
      };
    </script>
  </body>
</html>
